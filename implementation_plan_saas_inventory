### 2️⃣ Firestore Security Rules

```javascript
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ========== Helper Functions ==========
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserTenantId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tenantId;
    }

    function isTenantMember(tenantId) {
      return isAuthenticated() && getUserTenantId() == tenantId;
    }

    function isTenantOwner(tenantId) {
      return isTenantMember(tenantId) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'owner';
    }

    function hasActiveSubscription(tenantId) {
      let sub = get(/databases/$(database)/documents/tenants/$(tenantId)/subscription/active);
      return sub.data.status == 'active' || sub.data.status == 'trial';
    }

    // ========== User Profiles ==========
    match /users/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }

    // ========== Tenant Data ==========
    match /tenants/{tenantId}/{document=**} {
      allow read: if isTenantMember(tenantId);
      allow write: if isTenantMember(tenantId) && hasActiveSubscription(tenantId);
    }

    // ========== Subscription Plans (Public Read) ==========
    match /plans/{planId} {
      allow read: if true;
      allow write: if false; // admin only via backend
    }
  }
}
```

